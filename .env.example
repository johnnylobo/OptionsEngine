# Copy to .env and fill in values for local use.
#
# Tradier is the preferred provider for options chains because it supports
# bid/ask, volume, open interest, and Greeks on many option contracts.
OPTIONS_PROVIDER=tradier

# Use "sandbox" for Tradier's developer sandbox, or "live" for production data.
TRADIER_ENV=sandbox
TRADIER_ACCESS_TOKEN=replace_me

# Optional: currently reserved for a future Polygon provider adapter.
POLYGON_API_KEY=replace_me
