# Copy to .env and fill in values for local use.
#
# Provider selection:
# - auto: use Massive when MASSIVE_API_KEY exists, otherwise Tradier when configured.
# - massive: require MASSIVE_API_KEY or POLYGON_API_KEY.
# - tradier: require TRADIER_ACCESS_TOKEN.
# - demo: use local demo data only.
OPTIONS_PROVIDER=auto

# Preferred personal-beta provider.
MASSIVE_API_KEY=replace_me
# Optional. Use only when your provider subscription entitlement is confirmed.
# Accepted values: real-time, delayed, unknown.
MASSIVE_DATA_ENTITLEMENT=unknown

# Backward-compatible alias for Massive/Polygon accounts.
POLYGON_API_KEY=replace_me

# Use "sandbox" for Tradier's developer sandbox, or "live" for production data.
TRADIER_ENV=sandbox
TRADIER_ACCESS_TOKEN=replace_me
# Optional. Tradier sandbox is always treated as delayed.
TRADIER_DATA_ENTITLEMENT=unknown
